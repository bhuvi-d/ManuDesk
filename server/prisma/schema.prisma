datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("BDA Executive") // Admin, BDA Executive
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  clients   Client[]
  leads     Lead[]
  activities Activity[]
}

model Client {
  id                 String     @id @default(uuid())
  companyName        String     @unique
  industry           String
  procurementContact String
  email              String
  phone              String
  location           String
  productInterest    String
  annualRequirement  String
  status             String     @default("Active") // Active, Inactive
  assignedToId       String
  assignedTo         User       @relation(fields: [assignedToId], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  leads              Lead[]
  quotations         Quotation[]
  activities         Activity[]
}

model Lead {
  id                String      @id @default(uuid())
  companyName       String
  industry          String
  contactPerson     String
  stage             String      @default("New Inquiry") // New Inquiry, Requirement Discussion, Quotation Prepared, Quotation Sent, Negotiation, Purchase Order Received, Closed Won, Closed Lost
  dealValue         Float
  priority          String      @default("Medium") // Low, Medium, High
  expectedCloseDate DateTime
  clientId          String
  client            Client      @relation(fields: [clientId], references: [id])
  assignedToId      String
  assignedTo        User        @relation(fields: [assignedToId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  quotations        Quotation[]
  activities        Activity[]
}

model Quotation {
  id               String   @id @default(uuid())
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id])
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  product          String
  quantity         Int
  unitPrice        Float
  discount         Float    @default(0)
  deliveryTimeline String
  status           String   @default("Draft") // Draft, Sent, Under Review, Approved, Rejected
  terms            String
  totalValue       Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Activity {
  id          String   @id @default(uuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  type        String // Call, Email, Meeting, Site Visit, Follow-up, Negotiation Update
  description String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
